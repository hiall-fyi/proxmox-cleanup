#!/usr/bin/env node

const path = require('path');
const cliPath = path.join(__dirname, '..', 'dist', 'cli', 'index.js');

try {
  require(cliPath);
} catch (err) {
  if (err && err.code === 'MODULE_NOT_FOUND' && err.message.includes('dist/cli/index.js')) {
    console.error('proxmox-cleanup: build output is missing at ' + cliPath + '.');
    console.error('Run `npm run build` in the install directory, or reinstall the package.');
    process.exit(1);
  }
  throw err;
}
