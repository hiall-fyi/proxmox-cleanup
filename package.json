{
  "name": "proxmox-cleanup",
  "version": "1.3.0",
  "description": "Automated cleanup tool for unused Docker resources on Proxmox infrastructure",
  "main": "dist/index.js",
  "bin": {
    "proxmox-cleanup": "./bin/proxmox-cleanup"
  },
  "files": [
    "bin",
    "dist",
    "config.example.json",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src",
    "start": "node dist/cli/index.js",
    "prepack": "npm run build"
  },
  "keywords": [
    "proxmox",
    "docker",
    "cleanup",
    "devops"
  ],
  "author": "Joe Yiu",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.2",
    "commander": "^11.1.0",
    "dockerode": "^5.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.19.27",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^9.39.4",
    "fast-check": "^3.15.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  }
}
